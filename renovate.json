{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchPackageNames": ["seaweedfs/seaweedfs"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["^seaweedfs/Dockerfile$"],
      "matchStrings": ["ARG SEAWEEDFS_VERSION=\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "seaweedfs/seaweedfs"
    },
    {
      "fileMatch": ["^seaweedfs/build\\.yaml$"],
      "matchStrings": ["SEAWEEDFS_VERSION: \"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "seaweedfs/seaweedfs"
    }
  ]
}
